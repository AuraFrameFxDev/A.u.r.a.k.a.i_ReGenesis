# ═══════════════════════════════════════════════════════════════
# Genesis Protocol .gitignore - Complete Android + Python + AI
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# CLAUDE CODE — worktrees must never be committed
# ───────────────────────────────────────────────────────────────
.claude/worktrees/

# ───────────────────────────────────────────────────────────────
# LARGE GENERATED FILES / GENESIS ARTIFACTS
# ───────────────────────────────────────────────────────────────
agents_wired_files.txt
active_branch_files.txt
build_errors.txt
build_output.txt
build_output_errors.txt
build_output_errors_utf8.txt
build_result.txt
build_error.txt
gradle_output.txt
gradle_output_ascii.txt
ksp_log.txt
fix_manifest.txt
*.json
!package.json
!*.schema.json
!claude.json
!mcp_bridge/claude.json
!agents/*.json
!docs/context/agents/*.json

# ───────────────────────────────────────────────────────────────
# ANDROID BUILD ARTIFACTS
# ───────────────────────────────────────────────────────────────
*.iml
.gradle/
/local.properties
.idea/
.DS_Store
/build/
/captures/
.externalNativeBuild/
.cxx/
*.apk
*.ap_
*.aab

# Build outputs
*/build/
**/build/

# Gradle files
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# ───────────────────────────────────────────────────────────────
# SENSITIVE FILES (NEVER COMMIT)
# ───────────────────────────────────────────────────────────────
google-services.json
*-firebase-adminsdk-*.json
*.jks
*.keystore
keystore.properties
local.properties
secrets.properties

# API Keys
**/GEMINI_API_KEY
**/ANTHROPIC_API_KEY
**/*api*key*.txt

# ───────────────────────────────────────────────────────────────
# IDE FILES
# ───────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml

# Android Studio
.navigation/
captures/
output.json

# ───────────────────────────────────────────────────────────────
# KOTLIN
# ───────────────────────────────────────────────────────────────
*.kt.swp
*.kt~
.kotlin/

# ───────────────────────────────────────────────────────────────
# PYTHON BACKEND
# ───────────────────────────────────────────────────────────────
*.py[cod]
*$py.class
__pycache__/
*.so
.Python
env/
venv/
ENV/
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ───────────────────────────────────────────────────────────────
# LOGS & DATABASES
# ───────────────────────────────────────────────────────────────
*.log
*.sql
*.sqlite
*.db

# ───────────────────────────────────────────────────────────────
# OS FILES
# ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~

# ───────────────────────────────────────────────────────────────
# LOCKS
# ───────────────────────────────────────────────────────────────
*.lock

# ───────────────────────────────────────────────────────────────
# TEMP & CACHE
# ───────────────────────────────────────────────────────────────
*.tmp
*.temp
*.cache
.cache/

# ───────────────────────────────────────────────────────────────
# GENESIS PROTOCOL SPECIFIC
# ───────────────────────────────────────────────────────────────
# Keep documentation and context files tracked
!/docs/
!/context/
!/ai_backend/*.py

# But ignore generated reports
**/reports/
**/problems/
nul

# ───────────────────────────────────────────────────────────────
# LARGE FILES (GitHub Restrictions)
# ───────────────────────────────────────────────────────────────
*.hprof
*.mp4
*.bin
.gradle/*/executionHistory/

# Gradle lock/probe files (Fix Pack v1)
**/buildOutputCleanup.lock
**/*.probe
**/file-system.probe
**/gradle.lockfile
